{
  "name": "telegram-webapp",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "firebase": "^11.3.0",
    "firebase-admin": "^13.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.29.0",
    "react-scripts": "^5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "GENERATE_SOURCEMAP=false react-scripts build",
    "bootstrap": "bash scripts/bootstrap-machine.sh",
    "sync": "bash scripts/sync-local.sh",
    "verify": "DISABLE_ESLINT_PLUGIN=true npm run build",
    "verify:server": "node --check api/_lib/planner-store.js && node --check api/_lib/commitment-store.js && node --check api/_lib/capture-extractor.js && node --check api/_lib/telegram-task-memory.js && node --check api/_lib/planner-agent-router.js && node --check api/_lib/planner-action-executor.js && node --check api/telegram-webhook.js && node --check tests/planner-actions-contract.test.mjs",
    "test:contract": "node tests/planner-actions-contract.test.mjs"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
